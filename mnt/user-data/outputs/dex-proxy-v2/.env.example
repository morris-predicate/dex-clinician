# ── Claude (Anthropic) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=dex-sessions-yourname-prod

# ── DynamoDB tables (defaults shown — override only if you used different names) ──
DDB_PATIENTS_TABLE=dex-patients
DDB_VITALS_TABLE=dex-vitals

# ── Validic ───────────────────────────────────────────────────────────────────
# From your Validic Sandbox dashboard → Settings → Organizations
VALIDIC_BASE_URL=https://api.sandbox.validic.com
VALIDIC_ORG_ID=
VALIDIC_ORG_KEY=

# Webhook signing secret — get from Validic dashboard when you configure your webhook URL.
# Sandbox can run without it (insecure) — required for production.
VALIDIC_WEBHOOK_SECRET=

# ── Research Dashboard ────────────────────────────────────────────────────────
# Shared password for the investor/research dashboard.
# Pick anything strong — you'll share this directly with viewers.
# Example: openssl rand -hex 16
RESEARCH_DASHBOARD_KEY=

# ── Clinician Dashboard ───────────────────────────────────────────────────────
# Shared password for the clinician dashboard. Each clinic accesses via a
# URL like https://dex-clinician.netlify.app/?clinic=concierge-pilot-1
# The same password works for all clinics; clinic scoping is enforced by
# the URL parameter and server-side tenant isolation.
CLINICIAN_DASHBOARD_KEY=

# ── Frontend URLs ─────────────────────────────────────────────────────────────
# Patient PWA URL — used to build invite links sent to patients.
PWA_BASE_URL=https://your-pwa.vercel.app

# Comma-separated list of allowed CORS origins (PWA + clinician dashboard).
ALLOWED_ORIGINS=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
